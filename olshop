</div><div id="popup"></div><script>
let total = 0;

function masukToko(){
    document.getElementById('home').style.display='none';
    document.getElementById('shop').style.display='block';
}

function addToCart(n,p){
let c=document.getElementById('cartItems');
let d=document.createElement('div');
d.innerHTML=`<input type='checkbox' data-price='${p}' onchange='updateTotal()'> ${n} - Rp ${p} <button onclick='this.parentElement.remove();updateTotal()'>❌</button>`;
c.appendChild(d);
showPopup('✔ ditambah');
}

function updateTotal(){
let c=document.querySelectorAll('#cartItems input:checked');
total=0;
c.forEach(x=>total+=parseInt(x.dataset.price));
document.getElementById('total').innerText=total;
}

function beliLangsung(n,p){
let url="https://wa.me/6289520627841?text=Saya mau beli "+n+" Rp "+p;
window.open(url);
}

function checkout(){
if(total>0){
let url="https://wa.me/6289520627841?text=Pesan total Rp "+total;
window.open(url);
}
}

function showPopup(m){
let p=document.getElementById('popup');
p.innerText=m;
p.style.display='block';
setTimeout(()=>p.style.display='none',2000);
}
</script></body>
